{
  "name": "pitchit",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^11.3.1",
    "expo": "~55.0.0",
    "expo-av": "~15.1.0",
    "expo-constants": "~17.1.0",
    "expo-file-system": "~18.1.0",
    "expo-haptics": "~14.1.0",
    "expo-linking": "~7.1.0",
    "expo-router": "~5.1.0",
    "expo-sharing": "~13.1.0",
    "expo-sqlite": "~15.2.0",
    "expo-status-bar": "~2.2.0",
    "react": "^19.1.0",
    "react-native": "^0.81.4",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/react": "~19.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "ajv": "^8.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "typescript": "~5.8.0"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/app"
    ],
    "maxWorkers": 1,
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|@react-native/.*)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|uuid)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^../../../app/index$": "<rootDir>/app/index.tsx",
      "^../../../app/_layout$": "<rootDir>/app/_layout.tsx",
      "^../../../app/folder/\\[id\\]$": "<rootDir>/app/folder/[id].tsx",
      "^../../../app/record$": "<rootDir>/app/record.tsx",
      "^../../../app/recording/\\[id\\]$": "<rootDir>/app/recording/[id].tsx"
    }
  },
  "private": true
}
